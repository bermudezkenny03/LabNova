APP_NAME=LabNova
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://labnova-backend.onrender.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Base de datos PostgreSQL (Render la provee via DATABASE_URL) ---
DB_CONNECTION=pgsql
DATABASE_URL=

# --- Sesiones y cache (file, no requiere Redis ni DB) ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# --- CORS: URL del frontend en Vercel (separadas por coma si hay varias) ---
# Ejemplo: CORS_ALLOWED_ORIGINS=https://labnova.vercel.app
CORS_ALLOWED_ORIGINS=
